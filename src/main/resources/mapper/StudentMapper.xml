<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.example.curddemo.mapper.StudentMapper">
    <select id="getUserById" resultType="org.example.curddemo.entity.Student">
        select * from student where id = #{id}
    </select>
    <select id="findByName" resultType="org.example.curddemo.entity.Student">
        select * from student where name like CONCAT("%", #{name}, "%")
    </select>
    <select id="findByCondition" resultType="org.example.curddemo.entity.Student">
        select * from student
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT("%", #{name}, "%")
            </if>

            <if test="studentNo != null">
                AND student_no = #{studentNo}
            </if>
        </where>
    </select>
    <select id="getAll" resultType="org.example.curddemo.entity.Student">
        select * from student
    </select>
</mapper>